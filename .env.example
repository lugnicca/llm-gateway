# === LiteLLM Gateway Configuration ===

# Master key for admin API access
LITELLM_MASTER_KEY=sk-litellm-master-CHANGE-ME

# Salt key for hashing virtual keys
LITELLM_SALT_KEY=sk-litellm-salt-CHANGE-ME

# Database URL for key/spend tracking
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# Redis for caching
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === Provider Keys ===

# OpenRouter (sandbox, ZDR enabled)
OPENROUTER_API_KEY=sk-or-v1-CHANGE-ME

# Vertex AI (prod) — uses ADC on GCP, or set path for local
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json

# === Cloud Run Deployment ===
GCP_PROJECT_ID=litellm-489602
GCP_REGION=europe-west9
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json

# === PostgreSQL ===
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
